{
  "name": "AGIS Enterprise Dark",
  "description": "Anti-Gravity Intelligence System — Enterprise Operations Theme",
  "dataColors": [
    "#3B82F6",
    "#8B5CF6",
    "#F59E0B",
    "#22C55E",
    "#EF4444",
    "#06B6D4",
    "#EC4899",
    "#F97316",
    "#14B8A6",
    "#A855F7",
    "#64748B",
    "#0EA5E9"
  ],
  "background": "#0F172A",
  "foreground": "#E2E8F0",
  "tableAccent": "#3B82F6",
  "good": "#22C55E",
  "neutral": "#F59E0B",
  "bad": "#EF4444",
  "maximum": "#8B5CF6",
  "center": "#3B82F6",
  "minimum": "#F97316",
  "textClasses": {
    "callout": {
      "fontSize": 36,
      "fontFace": "Segoe UI Semibold",
      "color": "#E2E8F0"
    },
    "title": {
      "fontSize": 14,
      "fontFace": "Segoe UI Semibold",
      "color": "#E2E8F0"
    },
    "header": {
      "fontSize": 12,
      "fontFace": "Segoe UI Semibold",
      "color": "#94A3B8"
    },
    "label": {
      "fontSize": 11,
      "fontFace": "Segoe UI",
      "color": "#64748B"
    }
  },
  "visualStyles": {
    "*": {
      "*": {
        "general": [
          {
            "responsive": true
          }
        ],
        "background": [
          {
            "color": { "solid": { "color": "#1E293B" } },
            "transparency": 5
          }
        ],
        "border": [
          {
            "color": { "solid": { "color": "#334155" } },
            "radius": 8
          }
        ],
        "title": [
          {
            "show": true,
            "fontColor": { "solid": { "color": "#E2E8F0" } },
            "fontSize": 12,
            "fontFamily": "Segoe UI Semibold",
            "alignment": "left"
          }
        ],
        "padding": [
          {
            "top": 8,
            "bottom": 8,
            "left": 12,
            "right": 12
          }
        ]
      }
    },
    "page": {
      "*": {
        "background": [
          {
            "color": { "solid": { "color": "#0F172A" } },
            "transparency": 0
          }
        ]
      }
    },
    "card": {
      "*": {
        "labels": [
          {
            "color": { "solid": { "color": "#E2E8F0" } },
            "fontSize": 28,
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "categoryLabels": [
          {
            "color": { "solid": { "color": "#64748B" } },
            "fontSize": 11
          }
        ]
      }
    },
    "slicer": {
      "*": {
        "general": [
          {
            "outlineColor": { "solid": { "color": "#334155" } },
            "outlineWeight": 1
          }
        ],
        "items": [
          {
            "fontColor": { "solid": { "color": "#E2E8F0" } },
            "background": { "solid": { "color": "#1E293B" } }
          }
        ]
      }
    },
    "table": {
      "*": {
        "grid": [
          {
            "gridVertical": true,
            "gridVerticalColor": { "solid": { "color": "#334155" } },
            "gridHorizontal": true,
            "gridHorizontalColor": { "solid": { "color": "#334155" } }
          }
        ],
        "columnHeaders": [
          {
            "fontColor": { "solid": { "color": "#94A3B8" } },
            "backColor": { "solid": { "color": "#0F172A" } },
            "fontSize": 11
          }
        ],
        "values": [
          {
            "fontColor": { "solid": { "color": "#CBD5E1" } },
            "backColor": { "solid": { "color": "#1E293B" } },
            "fontSize": 10
          }
        ]
      }
    }
  }
}
